# Copy this file to .env and adjust values for your environment.
# Never commit the real .env file.

# Docker image/container naming
APP_NAME=mc-server
APP_VERSION=latest

# Port mapping: HOST_PORT is exposed on the host, CONTAINER_PORT is used inside the container.
HOST_PORT=8888
CONTAINER_PORT=25565

# Persistent Minecraft data directory inside the container.
DATA_DIR=/data

# Must be set to true in .env to accept the Minecraft EULA before the server starts.
EULA=false

# Official Minecraft example uses 4G. Lower this for local testing if needed.
JAVA_MEMORY=4G

# Minecraft world folder/name. Existing worlds should not be renamed casually.
LEVEL_NAME=your-world-name
